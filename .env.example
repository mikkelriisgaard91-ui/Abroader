# Copy to .env.local and fill in. Never commit .env.local.
# Vercel: Project → Settings → Environment Variables — add the same keys for Production (and Preview if needed), then Redeploy so the server sees them.
TEAMTAILOR_API_TOKEN=
# Optional. US West Teamtailor stack only (default is EU):
# TEAMTAILOR_API_BASE=https://api.na.teamtailor.com/v1
# Optional: public careersite origin (https://subdomain.teamtailor.com) for /language-jobs/job/[id] when GET /jobs/:id omits apply URLs (defaults to Abroader careersite).
# TEAMTAILOR_CAREERSITE_BASE=
#
# Optional: department id overrides (Partner API /departments) if name-based lookup fails for /language-jobs:
# TEAMTAILOR_GERMAN_DEPARTMENT_ID=
# TEAMTAILOR_DANISH_DEPARTMENT_ID=
# Optional: /hospitality (Seasonal Jobs) — if name aliases in seasonal-job-config.ts do not match:
# TEAMTAILOR_SEASONAL_DEPARTMENT_ID=
# Optional: /volunteering — if name aliases in volunteer-job-config.ts do not match:
# TEAMTAILOR_VOLUNTEER_DEPARTMENT_ID=
# Optional: home page sidebar — international recruiter job (Partner API job id):
# TEAMTAILOR_LANDING_INTERNATIONAL_RECRUITER_JOB_ID=
# (see env.d.ts for all TEAMTAILOR_*_DEPARTMENT_ID keys)
#
# Mailchimp newsletter signup (API route /api/newsletter)
# API key: Mailchimp → Account & Billing → Extras → API Keys
# Audience ID: Audience → Settings → Audience name and defaults → Audience ID
# Server: the prefix in your API key after the last dash (e.g. us21)
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER=
#
# Consultation form (/api/consultation — career support & travel booking)
# API key: Resend → API Keys (https://resend.com/api-keys)
RESEND_API_KEY=
# Optional. Defaults to Abroader <onboarding@resend.dev> (testing only; verify abroader.io for production).
# RESEND_FROM=Abroader <noreply@abroader.io>
# Optional. Inbox that receives consultation requests (default in code if unset: team Gmail until env is set).
# CONSULTATION_NOTIFY_EMAIL=mikkel@abroader.io
