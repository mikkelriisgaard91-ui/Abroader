# Copy to .env.local and fill in. Never commit .env.local.
# Vercel: Project → Settings → Environment Variables — add the same keys for Production (and Preview if needed), then Redeploy so the server sees them.
TEAMTAILOR_API_TOKEN=
# Optional. US West Teamtailor stack only (default is EU):
# TEAMTAILOR_API_BASE=https://api.na.teamtailor.com/v1
#
# Optional: department id overrides (Partner API /departments) if name-based lookup fails for /language-jobs:
# TEAMTAILOR_GERMAN_DEPARTMENT_ID=
# TEAMTAILOR_DANISH_DEPARTMENT_ID=
# Optional: /hospitality (Seasonal Jobs) — if name aliases in seasonal-job-config.ts do not match:
# TEAMTAILOR_SEASONAL_DEPARTMENT_ID=
# Optional: /volunteering — if name aliases in volunteer-job-config.ts do not match:
# TEAMTAILOR_VOLUNTEER_DEPARTMENT_ID=
# (see env.d.ts for all TEAMTAILOR_*_DEPARTMENT_ID keys)
